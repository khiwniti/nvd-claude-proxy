# Get a free key (no credit card) at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-replace-me

# Optional overrides — defaults shown
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
PROXY_HOST=127.0.0.1
PROXY_PORT=8788
PROXY_API_KEY=
LOG_LEVEL=INFO
# MODEL_CONFIG_PATH=config/models.yaml   # uncomment to use a custom models.yaml
REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES=2
RATE_LIMIT_RPM=0
MAX_REQUEST_BODY_MB=0
